<?xml version="1.0" encoding="utf-8"?>
<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" version="2.0">
  <xsl:template match="/" name="css">
    <style type="text/css">
      div.divXSLT{width:99%;margin:5px;}
      div.divXSLT table.titulo{width:100%;margin-bottom:2px;border-collapse:collapse;}
      div.divXSLT table.titulo thead td{font:normal normal bold 11px Verdana,Tahoma,Arial;color:#006D80;background-color:#E0EEF4;border:1px solid #7F9DB9;padding-left:5px;height:25px;}
      div.divXSLT table.dados{width:100%;border-collapse:collapse;margin-bottom:2px;}
      div.divXSLT table.dados thead td{font:normal normal bold 11px Verdana,Tahoma,Arial;color:#006D80;background-color:#E7EAEC;border:1px solid #7F9DB9;padding-left:5px;height:20px;}
      div.divXSLT table.dados tbody td{font:normal normal normal 11px Verdana,Tahoma,Arial;color:#000000;border:1px solid #7F9DB9;padding-left:5px;height:22px;}
    </style>
  </xsl:template>
</xsl:stylesheet>